@BASE_URL = http://localhost:5001

### Register
POST {{BASE_URL}}/auth/register
Content-Type: application/json

{
  "username": "pan",
  "email": "pan@email.com",
  "password": "123456",
  "role": "USER"
}

### Login
POST {{BASE_URL}}/auth/login
Content-Type: application/json

{
  "email": "pan@email.com",
  "password": "123456"
}